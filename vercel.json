{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "installCommand": "composer install --no-dev --prefer-dist --optimize-autoloader --no-interaction && npm install",
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4",
            "maxDuration": 60
        }
    },
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=(), payment=()"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/build/(.*)",
            "destination": "/build/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "/images/$1"
        },
        {
            "source": "/favicon.ico",
            "destination": "/favicon.ico"
        },
        {
            "source": "/robots.txt",
            "destination": "/robots.txt"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.php"
        }
    ]
}
